# Unity generated
/[Ll]ibrary/
/[Tt]emp/
/[Oo]bj/
/[Bb]uild/
/[Bb]uilds/
/[Ll]ogs/
/[Uu]ser[Ss]ettings/

# MemoryCaptures
/[Mm]emoryCaptures/

# Unity Editor–generated UIElements schema
/UIElementsSchema/

# Recordings
/[Rr]ecordings/

# Asset meta data should only be ignored when the corresponding asset is also ignored
!/[Aa]ssets/**/*.meta

# Autogenerated Crash Report
sysinfo.txt

# Builds
*.apk
*.aab
*.unitypackage
*.app

# Crashlytics
crashlytics-build.properties

# IDE
.vs/
.idea/
*.csproj
*.sln
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db

# OS
.DS_Store
Thumbs.db

# Keystore (contains signing keys - sensitive!)
/Keystore/
.vscode/

# Downloaded Unity packages (imported via Editor)
*.unitypackage

# Environment secrets
.env
yedi_benchmark/.env

# WebGL build output (large binary)
WebGLBuild/

# Python cache
__pycache__/
*.pyc

# Runtime data
scores.json
logs/
yedi_benchmark/data/

# LaTeX build artefacts (keep .tex, .bib, .pdf tracked)
paper/*.aux
paper/*.bbl
paper/*.blg
paper/*.log
paper/*.out
paper/*.toc
paper/*.synctex.gz
paper/audit/
